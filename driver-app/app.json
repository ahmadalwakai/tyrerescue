{
  "expo": {
    "name": "Tyre Rescue Driver",
    "slug": "tyre-rescue",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "tyrerescuedriver",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "uk.tyrerescue.driver",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Tyre Rescue uses your location to share your position with customers while you are on an active job, so they can track your arrival.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Tyre Rescue needs background location access so customers can track your arrival even when the app is in the background.",
        "UIBackgroundModes": [
          "location",
          "remote-notification"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090B"
      },
      "package": "uk.tyrerescue.driver",
      "versionCode": 3,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "WAKE_LOCK",
        "USE_FULL_SCREEN_INTENT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.USE_FULL_SCREEN_INTENT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Tyre Rescue needs background location access so customers can track your arrival even when the app is in the background.",
          "locationWhenInUsePermission": "Tyre Rescue uses your location to share your position with customers while you are on an active job, so they can track your arrival.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#F97316",
          "sounds": [
            "./assets/sounds/new_job.wav",
            "./assets/sounds/unvversfiled_ringtone_021_365652.mp3"
          ]
        }
      ],
      "expo-task-manager",
      "expo-font",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#09090B"
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c97a7bac-50da-42d8-9aef-3071d6b00925"
      }
    },
    "owner": "ahmadawadalwakai"
  }
}
