# EAS upload excludes. When present, EAS uses this instead of .gitignore to
# build the project archive. Mirrors .gitignore and additionally excludes the
# large local native build outputs, which the EAS build server regenerates.
# Keeping stale local Gradle outputs out of the upload prevents bloated
# archives and Gradle build failures from conflicting pre-built artifacts.

# Dependencies (restored on the build server)
node_modules/

# Expo / bundler caches & outputs
.expo/
dist/
web-build/

# Secrets — handled out-of-band by EAS (credentialsSource: local), never in the archive
*.jks
*.p8
*.p12
*.key
*.mobileprovision
credentials.json

# Misc
*.orig.*

# Env
.env
.env.local

# Native build outputs (regenerated by Gradle/Xcode on the build server).
# Native SOURCE (android/app/src, *.gradle, google-services.json) is kept.
android/build/
android/app/build/
android/.gradle/
android/.cxx/
android/app/.cxx/
ios/build/
ios/Pods/
