{
  "expo": {
    "name": "Tyre Rescue",
    "slug": "tyre-rescue",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tyrerescue",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "uk.tyrerescue.customer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Tyre Rescue uses your location to find your address and check emergency availability for your booking.",
        "NSPhotoLibraryUsageDescription": "Tyre Rescue lets you attach an optional tyre photo so the driver can prepare for your booking."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09090B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Tyre Rescue uses your location to find your address and check emergency availability for your booking."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Tyre Rescue lets you attach an optional tyre photo so the driver can prepare for your booking."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#09090B",
          "dark": {
            "backgroundColor": "#09090B"
          }
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": false
        }
      ],
      "@rnmapbox/maps",
      [
        "expo-notifications",
        {
          "mode": "production",
          "color": "#F97316",
          "defaultChannel": "booking_updates"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "ahmadawadalwakai",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c97a7bac-50da-42d8-9aef-3071d6b00925"
      }
    }
  }
}
