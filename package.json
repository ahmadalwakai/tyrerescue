{
  "name": "tyrerescue",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:seed": "dotenv -e .env.local -- tsx seed.ts",
    "seed:tyres": "dotenv -e .env.local -- tsx scripts/seed-tyres.ts",
    "seed:areas": "dotenv -e .env.local -- tsx scripts/seed-service-areas.ts",
    "seed:cookies": "dotenv -e .env.local -- tsx scripts/seed-cookie-settings.ts",
    "seed:stock": "dotenv -e .env.local -- tsx scripts/seed-from-excel.ts",
    "seed:hero": "dotenv -e .env.local -- tsx scripts/seed-hero-media.ts"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@neondatabase/serverless": "^1.0.2",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.9.0",
    "@vercel/blob": "^2.3.1",
    "barcode-detector": "^3.1.1",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.1",
    "groq-sdk": "^1.1.1",
    "mapbox-gl": "^3.20.0",
    "motion": "^12.38.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "stripe": "^20.4.1",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "ws": "^8.19.0"
  }
}
