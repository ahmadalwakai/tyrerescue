<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Alert heading -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/alert_heading"
            android:textColor="@color/colorDanger"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <!-- Booking ID -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/alert_booking_id_label"
            android:textColor="#A1A1AA"
            android:textSize="12sp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tv_booking_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorOnSurface"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="20dp" />

        <!-- Customer phone -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/alert_phone_label"
            android:textColor="#A1A1AA"
            android:textSize="12sp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tv_customer_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorOnSurface"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <!-- Created at -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/alert_created_at_label"
            android:textColor="#A1A1AA"
            android:textSize="12sp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tv_created_at"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorOnSurface"
            android:textSize="14sp"
            android:layout_marginBottom="40dp" />

        <!-- Open booking -->
        <Button
            android:id="@+id/btn_open_booking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_open_booking"
            android:backgroundTint="@color/colorPrimary"
            android:layout_marginBottom="12dp" />

        <!-- Acknowledge -->
        <Button
            android:id="@+id/btn_acknowledge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_acknowledge"
            android:backgroundTint="@color/colorSurface"
            android:layout_marginBottom="24dp" />

    </LinearLayout>

</ScrollView>
