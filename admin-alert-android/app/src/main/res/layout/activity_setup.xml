<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Heading -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_heading"
            android:textColor="@color/colorOnSurface"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Notification permission -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_permission_label"
            android:textColor="@color/colorOnSurface"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_permission_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checking…"
            android:textColor="@color/colorOnSurface"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <!-- Battery instructions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_battery_label"
            android:textColor="@color/colorOnSurface"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_battery_instructions"
            android:textColor="#A1A1AA"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- FCM token -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_fcm_token_label"
            android:textColor="@color/colorOnSurface"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_fcm_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fcm_token_loading"
            android:textColor="#A1A1AA"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_copy_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_copy_token"
            android:backgroundTint="@color/colorSurface"
            android:layout_marginBottom="24dp" />

        <!-- App settings -->
        <Button
            android:id="@+id/btn_open_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_open_settings"
            android:backgroundTint="@color/colorSurface"
            android:layout_marginBottom="12dp" />

        <!-- Test alert -->
        <Button
            android:id="@+id/btn_test_alert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_test_alert"
            android:backgroundTint="@color/colorPrimary"
            android:layout_marginBottom="24dp" />

    </LinearLayout>

</ScrollView>
